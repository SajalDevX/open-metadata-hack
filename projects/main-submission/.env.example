# Copy to .env and fill in. All entries are optional — the service runs without any.

# ── Service ────────────────────────────────────────────────────────────
COPILOT_HOST=0.0.0.0
COPILOT_PORT=8080
COPILOT_DB_PATH=runtime/incidents.db
COPILOT_DEFAULT_CHANNEL=#metadata-incidents

# ── OpenMetadata (for live context resolution) ─────────────────────────
# When both are set, the Context Resolver calls OpenMetadata's REST API
# instead of reading a local fixture.
# OPENMETADATA_BASE_URL=http://localhost:8585/api
# OPENMETADATA_JWT_TOKEN=eyJraWQi...

# Optional — route via OpenMetadata's MCP server instead of direct HTTP.
# Falls back to HTTP automatically if the MCP server is unreachable.
# USE_OM_MCP=true
# OPENMETADATA_MCP_URL=http://localhost:8787/mcp
# OPENMETADATA_MCP_TOOL=resolve_incident_context
# OPENMETADATA_MCP_TOKEN=

# ── OpenMetadata event polling (fallback to webhooks) ──────────────────
# Opt-in. When enabled, the service polls OM for recent test case results
# and dispatches newly-failed cases through the pipeline — same as if a
# webhook had arrived. Uses dedup by incident_id so the same failure isn't
# processed twice.
# COPILOT_ENABLE_POLLER=true
# COPILOT_POLLER_INTERVAL_SECONDS=60

# ── Slack delivery ─────────────────────────────────────────────────────
# When set, briefs are posted to this Slack webhook. Failed deliveries are
# queued and retried every 30s until they succeed or hit the max-attempts cap.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── AI narratives (OpenRouter) ─────────────────────────────────────────
# When set, RCA narrative and "what to do next" bullets come from Claude via
# OpenRouter. Without it, deterministic templates are used. Policy decisions
# are NEVER made by the AI — only narrative text.
# OPENROUTER_API_KEY=sk-or-...
